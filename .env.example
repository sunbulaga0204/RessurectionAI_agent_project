# ── LLM Provider ──────────────────────────────────────────
# Choose: "gemini" (default) or "claude"
LLM_PROVIDER=gemini

# ── API Keys ──────────────────────────────────────────────
# Gemini — required for the output/generation model
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic Claude (required only if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Voyage AI — required for embeddings (200M free tokens for new accounts)
# Get your key at: https://www.voyageai.com
VOYAGE_API_KEY=your-voyage-api-key-here

# ── Telegram Bot (optional) ──────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── Paths ─────────────────────────────────────────────────
SOURCES_DIR=./sources
CHROMA_DIR=./chroma_db
PERSONA_FILE=./persona.json
RESEARCH_NOTES_FILE=./research_notes.md

# ── Chunking ──────────────────────────────────────────────
# Approximate token count (1 token ≈ 4 chars for Arabic/English mixed text)
# Voyage supports up to 32,000 tokens per document — 800 is a balanced default
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── Retrieval ─────────────────────────────────────────────
TOP_K=8

# ── Generation ────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=voyage-3.5-lite
# MRL dimension: 256 | 512 | 1024 | 2048 (higher = more accurate, more storage)
VOYAGE_OUTPUT_DIMENSION=1024
CLAUDE_MODEL=claude-sonnet-4-20250514
TEMPERATURE=0.2
MAX_OUTPUT_TOKENS=8192

# ── Verification ──────────────────────────────────────────
ENABLE_VERIFICATION=true

# ── Rate Limiting ─────────────────────────────────────────
# Voyage supports up to 128 texts per batch with no artificial delay
EMBED_BATCH_SIZE=128
EMBED_DELAY_SECONDS=0

# ── Session Memory ────────────────────────────────────────
SESSION_TTL_HOURS=24
MAX_MEMORY_TURNS=20

# ── Web Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
