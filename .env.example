# ── LLM Provider ──────────────────────────────────────────
# Choose: "gemini" (free tier) or "claude" (paid, higher persona quality)
LLM_PROVIDER=gemini

# ── API Keys ──────────────────────────────────────────────
# Gemini (required if LLM_PROVIDER=gemini, also used for embeddings)
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic Claude (required only if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Telegram Bot (optional) ──────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── Paths ─────────────────────────────────────────────────
SOURCES_DIR=./sources
CHROMA_DIR=./chroma_db
PERSONA_FILE=./persona.json
RESEARCH_NOTES_FILE=./research_notes.md

# ── Chunking ──────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval ─────────────────────────────────────────────
TOP_K=10

# ── Generation ────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
CLAUDE_MODEL=claude-sonnet-4-20250514
TEMPERATURE=0.2
MAX_OUTPUT_TOKENS=8192

# ── Verification ──────────────────────────────────────────
ENABLE_VERIFICATION=true

# ── Rate Limiting (free tier) ─────────────────────────────
EMBED_BATCH_SIZE=5
EMBED_DELAY_SECONDS=4

# ── Session Memory ────────────────────────────────────────
# Maximum session age in hours before context is cleared
SESSION_TTL_HOURS=24
# Maximum conversation turns to keep in memory per session
MAX_MEMORY_TURNS=20

# ── Web Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
